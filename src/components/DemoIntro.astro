---
// The pitch: what this is and what it demonstrates. Emphasized (primary) copy.
const points = [
  "Payment Element — own the UI, not PCI scope",
  "Server-authoritative pricing — the client never sends an amount",
  "Webhook-driven fulfillment, idempotent & replay-safe",
  "Full 3-D Secure, processing & decline handling",
  "One shared confirm path for both plans",
];
---

<div class="intro">
  <h1 id="demo-title">A demo checkout page</h1>
  <p class="sub">
    One product, sold two ways — one-time or subscription. Under the hood:
  </p>
  <ul class="points">
    {points.map((p) => <li>{p}</li>)}
  </ul>
</div>

<style>
  h1 {
    font-size: clamp(1.75rem, 4vw, 2.375rem);
    font-weight: 680;
    letter-spacing: -0.03em;
    margin: 0 0 0.875rem;
  }
  .sub {
    margin: 0 0 1.5rem;
    font-size: var(--text-base);
    line-height: 1.55;
    color: var(--color-ink-700);
    max-width: 44ch;
  }
  .points {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.55rem;
    max-width: 46ch;
  }
  .points li {
    position: relative;
    padding-left: 1.5rem;
    font-size: var(--text-sm);
    line-height: 1.45;
    color: var(--color-ink-700);
  }
  .points li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.45em;
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 2px;
    background: var(--color-accent);
  }
</style>
