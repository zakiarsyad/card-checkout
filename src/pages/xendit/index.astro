---
import Layout from "../../layouts/Layout.astro";
import { BRAND } from "../../lib/brand";
import DemoIntro from "../../components/xendit/DemoIntro.astro";
import CheckoutShell from "../../components/CheckoutShell.astro";
import SourceLink from "../../components/SourceLink.astro";
---

<Layout provider="xendit" title={`${BRAND.name} — a Xendit checkout demo`}>
  <main class="page">
    <!-- Left: what it is + how to run it -->
    <section class="info" aria-labelledby="demo-title">
      <DemoIntro />
    </section>

    <!-- Right: the live checkout -->
    <section class="checkout" aria-label="Checkout">
      <CheckoutShell provider="xendit" locale="id-ID" />
      <SourceLink />
    </section>
  </main>

  <script>
    import { initCheckout } from "../../scripts/xendit/checkout";
    initCheckout();
  </script>
</Layout>

<style>
  .page {
    min-height: 100dvh;
    max-width: 34rem; /* single column: a centered column sized to the card (≥860px widens to two columns below) */
    margin-inline: auto;
    padding: clamp(1.5rem, 5vw, 3rem) clamp(1rem, 4vw, 2rem);
    display: grid;
    gap: clamp(1.75rem, 4vw, 3rem);
  }
  @media (min-width: 860px) {
    .page {
      max-width: 900px;
      grid-template-columns: 1fr 400px;
      align-items: start;
    }
  }
  .info {
    min-width: 0; /* let the grid column shrink to the viewport on small screens */
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .checkout {
    min-width: 0; /* ditto — without this the card's content can force h-overflow < ~330px */
    width: 100%;
    max-width: 30rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
</style>
